# ===========================================
# Kratos Login UI — Runtime Configuration
# ===========================================
# All values below are read at REQUEST time via `next-runtime-env`.
# The same Docker image works in any environment — set these as container
# env vars (no rebuild needed).
#
# `NEXT_PUBLIC_*` values are exposed to the browser at runtime; non-prefixed
# values are server-side only.

# -------------------------------------------
# Branding
# -------------------------------------------
NEXT_PUBLIC_APP_NAME="Auth"

# Logo URL — accepts either:
#   - a local path served from /public  (e.g. "/logo.svg", "/brand/my-logo.svg")
#   - a remote URL                       (e.g. "https://cdn.example.com/logo.svg")
NEXT_PUBLIC_LOGO_URL="/logo.svg"

# Favicon — same rules as logo
NEXT_PUBLIC_FAVICON_URL="/favicon.ico"

# -------------------------------------------
# Theme (hex colors without #)
# -------------------------------------------
NEXT_PUBLIC_THEME_PRIMARY_COLOR="3B82F6"
NEXT_PUBLIC_THEME_DARK_MODE="true"
NEXT_PUBLIC_THEME_BACKGROUND_COLOR="111827"

# -------------------------------------------
# Kratos
# -------------------------------------------
# Browser-facing Kratos public URL (used for redirects from the client)
NEXT_PUBLIC_KRATOS_BROWSER_URL="https://auth.example.com"
# In-cluster Kratos URL (server-side calls only; no NEXT_PUBLIC_ prefix)
KRATOS_PUBLIC_URL="http://kratos-public.kratos.svc.cluster.local:80"

# -------------------------------------------
# Redirects
# -------------------------------------------
NEXT_PUBLIC_DEFAULT_RETURN_URL="https://app.example.com"
# Comma-separated list of allowed return_to origins. Supports * wildcards.
NEXT_PUBLIC_ALLOWED_RETURN_URLS="https://*.example.com"

# -------------------------------------------
# Optional copy
# -------------------------------------------
NEXT_PUBLIC_LOGIN_TITLE="Welcome back"
NEXT_PUBLIC_LOGIN_SUBTITLE="Sign in to your account"
NEXT_PUBLIC_REGISTER_TITLE="Create account"
NEXT_PUBLIC_REGISTER_SUBTITLE="Get started with your account"
NEXT_PUBLIC_RECOVERY_TITLE="Reset password"
NEXT_PUBLIC_RECOVERY_SUBTITLE="Enter your email to reset your password"
NEXT_PUBLIC_VERIFICATION_TITLE="Verify your email"
NEXT_PUBLIC_VERIFICATION_SUBTITLE="Enter the code sent to your email"

# -------------------------------------------
# Optional footer
# -------------------------------------------
NEXT_PUBLIC_FOOTER_TEXT=""
# JSON array of {label, url}
NEXT_PUBLIC_FOOTER_LINKS='[]'
